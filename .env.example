# Application
APP_NAME=Morf
APP_ENV=production
APP_KEY=
APP_DEBUG=false

# Если есть домен:
# APP_URL=https://your-domain.com
# Если только IP:
APP_URL=http://91.227.68.182:8080

# Database
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=morf
DB_USERNAME=morf_user
DB_PASSWORD=change_this_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Queue & Cache
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# Storage
FILESYSTEM_DISK=public

# Sanctum (добавь IP или домен через запятую)
# Для IP:
SANCTUM_STATEFUL_DOMAINS=91.227.68.182:3000,91.227.68.182:8080,localhost:3000
# Для домена:
# SANCTUM_STATEFUL_DOMAINS=localhost:3000,your-domain.com

# Frontend API (внутри Docker network)
API_HOST=web
API_PORT=80
